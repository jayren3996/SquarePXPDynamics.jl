exec
/usr/bin/bash -lc "julia --project=. -e '
using JSON3
path=\"artifacts/m3-systematic/threaded-ctm-trajectory-3x3-t020-dt002-D2D3D4-chi2chi4.json\"
data=JSON3.read(read(path,String))
println(typeof(data)); println(keys(data))
println(\"config=\", data.config)
println(\"summaries len=\", length(data.summaries))
for s in data.summaries
    println(\"SUMMARY D=\", s.D, \" ctm_err=\", s.density_error_ctm, \" simple_err=\", s.density_error_simple, \" trust=\", s.ctm_trust_status, \"/\", s.ctm_trust_reason, \" finite_chi_delta=\", get(s,:finite_chi_density_delta,nothing), \" maxres=\", get(s,:finite_chi_max_residual,nothing))
end
println(\"runs=\", length(data.runs))
for r in data.runs
    println(\"RUN D=\", r.config.D, \" samples=\", length(r.ipeps_samples), \" comps=\", length(r.comparisons))
    fs=r.ipeps_samples[end]
    println(\" final simple=\", fs.measurement.density, \" lognorm=\", fs.log_norm, \" exact=\", fs.exact_finite_density)
